<ol class="spellcastingEntry-list directory-list unified-spell-list" style="display:none; margin-bottom:8px;">

  {{#each ranks}}
  <li class="item item-container spellcasting-entry">

    {{!-- ─── RANK HEADER ──────────────────────────────────────────────── --}}
    <div class="action-header" style="display: flex; align-items: center; justify-content: space-between;">
      <h3 class="item-name">
        <span style="padding: 0 8px;">{{rankLabel}}</span>
      </h3>
      {{!-- Focus pool: compact, right-aligned ─────────────────────────── --}}
      {{#if isFocus}}
      <section class="focus-pool"
        data-action="adjust-resource"
        data-resource="focus"
        style="cursor: pointer; display: flex; align-items: center; gap: 4px; font-size: 0.9em; font-weight: 500; opacity: 0.9; padding-right: 8px; white-space: nowrap; flex-shrink: 0;"
        title="PF2E.Focus.Pool"
      >
        <span style="color: white; font-weight: 700; margin-right: 2px;">{{localize "PF2E.Focus.Pool"}}</span>
        {{#each focusSlots}}
          <i class="{{#if expended}}fa-regular fa-circle{{else}}fa-solid fa-circle-dot{{/if}}" style="font-size: 0.9em; color: white;"></i>
        {{/each}}
      </section>
      {{/if}}
    </div>

    {{!-- ─── SPELL LIST ───────────────────────────────────────────────── --}}
    <ol class="spell-list">

      {{#each sources}}

        {{!-- ─── SOURCE HEADER ROW ──────────────────────────────────────── --}}
        <li class="header-row"
          data-item-id="{{itemId}}"
          data-group-id="{{#if ../isCantrip}}cantrips{{else}}{{slotNum}}{{/if}}"
          style="position: relative;{{#if @first}} margin-top: 6px;{{/if}} background: rgba(0,0,0,0.04); border-top: 1px solid var(--color-border-light-tertiary, #ccc); border-bottom: 1px solid var(--color-border-light-tertiary, #ccc);"
        >
          <div class="item-name" style="gap: 6px;">
            <h3 style="font-size: 0.82em; opacity: 0.75; margin: 0;">{{entryName}}</h3>

            {{!-- Slot info (non-cantrip only) ───────────────────────────── --}}
            {{#unless ../isCantrip}}

              {{#if (unifiedEq slotInfo.type "spontaneous")}}
                <span class="spell-slots-input">
                  <input type="number" data-item-id="{{itemId}}" data-item-property="system.slots.slot{{slotNum}}.value" value="{{slotInfo.current}}" placeholder="0" />
                </span>
                <span class="slash">/</span>
                <span class="spell-max-input">
                  <input type="number" data-item-id="{{itemId}}" data-item-property="system.slots.slot{{slotNum}}.max" value="{{slotInfo.max}}" placeholder="0" />
                </span>
                <a data-action="reset-spell-slots"><i class="fa-solid fa-arrow-rotate-right"></i></a>
              {{/if}}

              {{#if (unifiedEq slotInfo.type "equipment")}}
                <span style="font-size: 0.9em; opacity: 0.65;">
                  {{localize "pf2e-unified-spellbook.Item"}} x{{slotInfo.quantity}}
                </span>
              {{/if}}

              {{#if (unifiedEq slotInfo.type "staff")}}
                <div class="pf2e-dailies-charges">
                  <input type="number" data-action="change-charges-unified" min="0" max="{{slotInfo.max}}" value="{{slotInfo.current}}" step="1" />
                  <a data-action="reset-charges-unified"><i class="fas fa-redo"></i></a>
                </div>
              {{/if}}

            {{/unless}}
          </div>

          <div class="defense">{{localize "pf2e-unified-spellbook.Defense"}}</div>

          {{!-- Column header: "Uses" for innate, "Range" for all others ── --}}
          {{#if (unifiedEq slotInfo.type "innate")}}
            <div class="uses">{{localize "pf2e-unified-spellbook.Uses"}}</div>
          {{else}}
            <div class="range">{{localize "pf2e-unified-spellbook.Range"}}</div>
          {{/if}}

          {{!-- Roll button ─────────────────────────────────────────────── --}}
          <a class="skill-data rollable"
            data-action="roll-check"
            data-statistic="{{entryDataStatistic}}"
            data-tooltip="Spell Attack Roll {{stats.attack}}"
            style="position: absolute; right: 32px; top: 50%; transform: translateY(-50%); opacity: 0.7; font-size: 0.9em; cursor: pointer;"
          >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="-1 0 19 19"
       style="width: 1em; height: 1em; display: block; transition: transform 0.5s ease, filter 0.2s ease;">
    <path fill-rule="evenodd" fill="currentColor" d="M3.826,8.060 L0.124,13.540 C0.016,13.716 0.127,13.944 0.332,13.967 L7.637,14.743 L3.826,8.060 L3.826,8.060 ZM0.341,11.589 L2.983,7.288 L0.294,5.672 C0.200,5.615 0.081,5.683 0.081,5.792 L0.081,11.515 C0.081,11.657 0.267,11.710 0.341,11.589 ZM0.722,15.391 L7.541,18.472 C7.727,18.559 7.939,18.422 7.939,18.217 L7.939,15.908 L0.799,15.125 C0.643,15.107 0.580,15.321 0.722,15.391 L0.722,15.391 ZM3.571,6.330 L6.375,1.305 C6.527,1.057 6.249,0.769 5.996,0.913 L0.706,4.380 C0.620,4.437 0.622,4.565 0.711,4.618 L3.571,6.330 L3.571,6.330 ZM8.500,6.687 L12.331,6.687 L8.978,0.769 C8.869,0.590 8.684,0.501 8.500,0.501 C8.316,0.501 8.132,0.590 8.022,0.769 L4.669,6.687 L8.500,6.687 ZM16.707,5.672 L14.018,7.288 L16.659,11.589 C16.733,11.710 16.919,11.657 16.919,11.515 L16.919,5.792 C16.919,5.683 16.800,5.615 16.707,5.672 ZM13.430,6.330 L16.290,4.618 C16.379,4.564 16.381,4.436 16.294,4.379 L11.004,0.913 C10.752,0.769 10.474,1.057 10.626,1.305 L13.430,6.330 ZM16.202,15.125 L9.062,15.908 L9.062,18.217 C9.062,18.422 9.274,18.558 9.460,18.472 L16.279,15.391 C16.420,15.321 16.358,15.107 16.202,15.125 L16.202,15.125 ZM13.175,8.060 L9.364,14.743 L16.669,13.967 C16.874,13.944 16.986,13.716 16.877,13.540 L13.175,8.060 L13.175,8.060 ZM8.500,7.812 L4.977,7.812 L8.500,13.990 L12.023,7.812 L8.500,7.812 Z"/>
  </svg>
          </a>


          {{!-- Tradition badge ─────────────────────────────────────────── --}}
          <div class="tradition-badge"
            style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); cursor: help; opacity: 0.8;"
            data-tooltip="<strong>{{traditionName}} - {{stats.proficiency}}</strong><br/>DC {{stats.dc}} | Attack {{stats.attack}}"
          >
            <i class="fa-solid {{traditionIcon}}"></i>
          </div>

          <button type="button" class="cast-spell blue invisible">Cast</button>
          <div class="item-controls invisible"></div>
        </li>

        {{!-- ─── SPELL ROWS ──────────────────────────────────────────────── --}}
        {{#each spells}}
        <li
          class="spell{{#if isVirtual}} virtual{{/if}}"
          style="{{#if (unifiedAnd isVirtual (unifiedNot isFlexible))}}background: rgba(50, 100, 200, 0.08);{{/if}}"
          data-item-type="{{#if isVirtual}}spell-slot-group{{else}}spell{{/if}}"
          data-item-id="{{_id}}"
          data-entry-id="{{entryId}}"
          data-cast-rank="{{castRank}}"
          data-group-id="{{groupId}}"
          {{#if slotId}}data-slot-id="{{slotId}}"{{/if}}
          {{#if (unifiedOr expended (unifiedAnd isAnimistVesselSpell (unifiedNot isPrimaryAnimistVesselSpell)))}}data-slot-expended=""{{/if}}
        >
          {{!-- Spell name + icon ────────────────────────────────────────── --}}
          <div class="item-name{{#unless isVirtual}} drag-handle{{/unless}}"
            {{#unless isVirtual}}data-drag-handle=""{{/unless}}>
            <a class="item-image framed" data-action="item-to-chat">
              <img class="item-icon" src="{{img}}">
              <i class="fa-solid fa-message"></i>
            </a>
            <h4 class="name">
              <a data-action="toggle-summary">{{name}}</a>
              <span class="action-glyph">{{actions}}</span>
              {{#if isFocusCantrip}}
                <span style="font-size: 0.65em; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; background: var(--color-background-info); color: var(--color-text-info); border: 1px solid rgba(0, 0, 0, 0.2); border-radius: 3px; padding: 1px 5px; vertical-align: middle;">Cantrip</span>
              {{/if}}
            </h4>
          </div>

          <div class="defense">{{defense}}</div>

          {{!-- Range / Uses column ────────────────────────────────────────── --}}
          {{#if (unifiedAnd hasUses (unifiedNot (unifiedEq groupId "cantrips")))}}
            <div class="uses">
              <span class="spell-slots-input">
                <input type="number" data-item-id="{{_id}}" data-item-property="system.location.uses.value" value="{{uses.value}}" placeholder="0" />
              </span>
              <span class="slash"> / </span>
              <span class="spell-max-input">
                <input type="number" data-item-id="{{_id}}" data-item-property="system.location.uses.max" value="{{uses.max}}" placeholder="0" />
              </span>
            </div>
          {{else}}
            <div class="range">{{range}}</div>
          {{/if}}

          {{!-- Cast / Draw button ─────────────────────────────────────────── --}}
          {{#if isItem}}
            <button type="button" class="cast-spell blue" data-action="{{#if isDrawn}}cast-spell{{else}}draw-item{{/if}}" {{#unless isDrawn}}data-item-id="{{itemId}}"{{/unless}}>
              {{#if isDrawn}}Cast{{else}}{{localize "pf2e-unified-spellbook.Draw"}}{{/if}}
            </button>
          {{else}}
            <button type="button" class="cast-spell blue{{#if (unifiedAnd isAnimistVesselSpell (unifiedNot isPrimaryAnimistVesselSpell))}} inactive{{/if}}" data-action="cast-spell">
              {{localize "pf2e-unified-spellbook.Cast"}}
            </button>
          {{/if}}

          {{!-- Item controls ──────────────────────────────────────────────── --}}
          <div class="item-controls">

            {{#if (unifiedAnd isAnimistVesselSpell (unifiedNot isPrimaryAnimistVesselSpell))}}
              <a data-action="dailies-retrain-unified" data-retrain-type="vessel" data-tooltip="Exchange Primary Vessel">
                <i class="fa-solid fa-retweet"></i>
              </a>
            {{/if}}

            {{#unless (unifiedOr (unifiedEq groupId "cantrips") isFlexible)}}
              {{#if (unifiedEq prepType "spontaneous")}}
                <a data-action="toggle-signature-spell" data-tooltip="PF2E.ToggleSignatureSpellTitle">
                  <i class="fa-fw fa-star {{#if isSignature}}fa-solid{{else}}fa-regular{{/if}}"></i>
                </a>
              {{/if}}
              {{#if (unifiedEq prepType "prepared")}}
                <a data-action="toggle-slot-expended" data-tooltip="{{#if expended}}PF2E.RestoreSpellTitle{{else}}PF2E.ExpendSpellTitle{{/if}}">
                  <i class="fa-solid fa-fw {{#if expended}}fa-plus-square{{else}}fa-minus-square{{/if}}"></i>
                </a>
              {{/if}}
            {{/unless}}

            {{#if (unifiedAnd hasUses (unifiedNot (unifiedEq groupId "cantrips")))}}
              <a data-action="reset-spell-slots" data-tooltip="{{localize "pf2e-unified-spellbook.ResetSpellSlots"}}"><i class="fa-solid fa-arrow-rotate-right"></i></a>
            {{/if}}
            {{#unless isVirtual}}
              <a data-action="edit-item" data-tooltip="PF2E.EditItemTitle"><i class="fa-solid fa-fw fa-edit"></i></a>
              <a data-action="delete-item" data-tooltip="PF2E.DeleteItemTitle"><i class="fa-solid fa-fw fa-trash"></i></a>
            {{/unless}}

          </div>

          <div class="item-summary" hidden=""></div>
        </li>
        {{/each}}{{!-- end spells --}}

      {{/each}}{{!-- end sources --}}

    </ol>
  </li>
  {{/each}}{{!-- end ranks --}}

</ol>
