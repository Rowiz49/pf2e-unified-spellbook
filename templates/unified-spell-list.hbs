<ol class="spellcastingEntry-list directory-list unified-spell-list" style="display:none; margin-bottom:8px;">

  {{!-- ─── RANK GROUPS ─────────────────────────────────────────────── --}}
  {{#each ranks}}
  <li class="item item-container spellcasting-entry">

    <div class="action-header">
      <h3 class="item-name">
        <span style="padding: 0 8px;">{{rankLabel}}</span>
      </h3>
    </div>

    <ol class="spell-list">

      {{!-- ─── SOURCE HEADERS ───────────────────────────────────────── --}}
      {{#each sources}}

        {{!-- Cantrip header (no slot info needed) --}}
        {{#if ../isCantrip}}
        <li class="header-row"
          data-item-id="{{itemId}}"
          data-group-id="cantrips"
          style="
            position: relative;
            {{#if @first}}margin-top: 6px;{{/if}}
            background: rgba(0,0,0,0.04);
            border-top: 1px solid var(--color-border-light-tertiary, #ccc);
            border-bottom: 1px solid var(--color-border-light-tertiary, #ccc);
          "
        >
          <div class="item-name" style="gap: 6px;">
            <h3 style="font-size: 0.82em; opacity: 0.75; margin: 0;">{{entryName}}</h3>
          </div>
          <div class="defense">{{localize "pf2e-unified-spellbook.Defense"}}</div>
          <div class="range">{{localize "pf2e-unified-spellbook.Range"}}</div>

          <div class="tradition-badge" 
              style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); cursor: help; opacity: 0.8;" 
              data-tooltip="<strong>{{traditionName}} - {{stats.proficiency}} </strong><br/>DC {{stats.dc}} | Attack {{stats.attack}}">
            <i class="fa-solid {{traditionIcon}}"></i>
          </div>

          <button type="button" class="cast-spell blue invisible">Cast</button>
          <div class="item-controls invisible"></div>
        </li>

        {{!-- Spell rank header (with slot info depending on entry type) --}}
        {{else}}
        <li class="header-row"
          data-item-id="{{itemId}}"
          data-group-id="{{slotNum}}"
          style="
            position: relative;
            {{#if @first}}margin-top: 6px;{{/if}}
            background: rgba(0,0,0,0.04);
            border-top: 1px solid var(--color-border-light-tertiary, #ccc);
            border-bottom: 1px solid var(--color-border-light-tertiary, #ccc);
          "
        >
          <div class="item-name" style="gap: 6px;">
            <h3 style="font-size: 0.82em; opacity: 0.75; margin: 0;">{{entryName}}</h3>

            {{!-- Spontaneous: editable current / max slots --}}
            {{#if (unifiedEq slotInfo.type "spontaneous")}}
              <span class="spell-slots-input">
                <input type="number"
                  data-item-id="{{itemId}}"
                  data-item-property="system.slots.slot{{slotNum}}.value"
                  value="{{slotInfo.current}}"
                  placeholder="0"
                />
              </span>
              <span class="slash">/</span>
              <span class="spell-max-input">
                <input type="number"
                  data-item-id="{{itemId}}"
                  data-item-property="system.slots.slot{{slotNum}}.max"
                  value="{{slotInfo.max}}"
                  placeholder="0"
                />
              </span>
              <a data-action="reset-spell-slots">
                <i class="fa-solid fa-arrow-rotate-right"></i>
              </a>
            {{/if}}

            {{!-- Focus: pip display, click/right-click to adjust --}}
            {{#if (unifiedEq slotInfo.type "focus")}}
              <section class="focus-pool" data-action="adjust-resource" data-resource="focus" style="cursor: pointer;">
                <span class="pips">
                  {{#each slotInfo.slots}}
                    <i class="{{#if expended}}fa-regular fa-circle{{else}}fa-solid fa-circle-dot{{/if}}"></i>
                  {{/each}}
                </span>
              </section>
            {{/if}}

            {{!-- Equipment: static label --}}
            {{#if (unifiedEq slotInfo.type "equipment")}}
              <span style="font-size: 0.78em; opacity: 0.65;">
                {{localize "pf2e-unified-spellbook.Item"}} x{{slotInfo.quantity}}
              </span>
            {{/if}}

            {{!-- Staff (pf2e-dailies): charge input + reset --}}
            {{#if (unifiedEq slotInfo.type "staff")}}
              <div class="pf2e-dailies-charges">
                <input type="number"
                  data-action="change-charges-unified"
                  min="0"
                  max="{{slotInfo.max}}"
                  value="{{slotInfo.current}}"
                  step="1"
                />
                <a data-action="reset-charges-unified">
                  <i class="fas fa-redo"></i>
                </a>
              </div>
            {{/if}}

          </div>

          <div class="defense">{{localize "pf2e-unified-spellbook.Defense"}}</div>

          {{!-- Innate spells show "Uses" instead of "Range" in the column header --}}
          {{#if (unifiedEq slotInfo.type "innate")}}
            <div class="range">{{localize "pf2e-unified-spellbook.Uses"}}</div>
          {{else}}
            <div class="range">{{localize "pf2e-unified-spellbook.Range"}}</div>
          {{/if}}

        <div class="tradition-badge" 
             style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); cursor: help; opacity: 0.8;" 
             data-tooltip="<strong>{{traditionName}} - {{stats.proficiency}} </strong><br/>DC {{stats.dc}} | Attack {{stats.attack}} ">
          <i class="fa-solid {{traditionIcon}}"></i>
        </div>

        <button type="button" class="cast-spell blue invisible">Cast</button>
        <div class="item-controls invisible"></div>

        </li>
        {{/if}}

        {{!-- ─── SPELL ROWS ─────────────────────────────────────────── --}}
        {{#each spells}}
        <li
          class="spell{{#if isVirtual}} virtual{{/if}}"
          style="{{#if (unifiedAnd isVirtual (unifiedNot isFlexible))}} background: rgba(50, 100, 200, 0.08);{{/if}}"
          data-item-type="{{#if isVirtual}}spell-slot-group{{else}}spell{{/if}}"
          data-item-id="{{_id}}"
          data-entry-id="{{entryId}}"
          data-cast-rank="{{castRank}}"
          data-group-id="{{groupId}}"
          {{#if slotId}}data-slot-id="{{slotId}}"{{/if}}
          {{#if (unifiedOr expended (unifiedAnd isAnimistVesselSpell (unifiedNot isPrimaryAnimistVesselSpell)))}}data-slot-expended=""{{/if}}
        >

          {{!-- Spell name + icon --}}
          <div class="item-name{{#unless isVirtual}} drag-handle{{/unless}}"
            {{#unless isVirtual}}data-drag-handle=""{{/unless}}>
            <a class="item-image framed" data-action="item-to-chat">
              <img class="item-icon" src="{{img}}">
              <i class="fa-solid fa-message"></i>
            </a>
            <h4 class="name">
              <a data-action="toggle-summary">{{name}}</a>
              <span class="action-glyph">{{actions}}</span>
            </h4>
          </div>

          <div class="defense">{{defense}}</div>

          {{!-- Range / Uses column --}}
          {{#if hasUses}}
            {{!-- Cantrips don't track uses, just show range --}}
            {{#if (unifiedEq groupId "cantrips")}}
              <div class="range">{{range}}</div>
            {{else}}
              {{!-- Innate / limited-use spells: editable uses with reset --}}
              <div class="uses" style="margin-right: 16px;">
                <input type="number"
                  data-item-id="{{_id}}"
                  data-item-property="system.location.uses.value"
                  value="{{uses.value}}"
                  placeholder="0"
                />
                <span class="slash">/</span>
                  <input type="number"
                  data-item-id="{{_id}}"
                  data-item-property="system.location.uses.max"
                  value="{{uses.max}}"
                  placeholder="0"
                />
                <a data-action="reset-spell-slots" data-tooltip="Reset Uses">
                  <i class="fa-solid fa-arrow-rotate-right"></i>
                </a>
              </div>
            {{/if}}
          {{else}}
            <div class="range">{{range}}</div>
          {{/if}}

          {{!-- Cast / Draw button --}}
          {{#if isItem}}
            {{#if isDrawn}}
              <button type="button" class="cast-spell blue" data-action="cast-spell">Cast</button>
            {{else}}
              <button type="button" class="cast-spell blue" data-action="draw-item" data-item-id="{{itemId}}">
                {{localize "pf2e-unified-spellbook.Draw"}}
              </button>
            {{/if}}
          {{else}}
            
              <button type="button" class="cast-spell blue {{#if (unifiedAnd isAnimistVesselSpell (unifiedNot isPrimaryAnimistVesselSpell))}} inactive {{/if}}" data-action="cast-spell" >
                {{localize "pf2e-unified-spellbook.Cast"}}
              </button>
          {{/if}}

          {{!-- Item controls (edit, delete, signature, expend) --}}
          <div class="item-controls">
            {{#if (unifiedAnd isAnimistVesselSpell (unifiedNot isPrimaryAnimistVesselSpell))}}
            <a data-action="dailies-retrain-unified" data-retrain-type="vessel" data-tooltip="Exchange Primary Vessel"><i class="fa-solid fa-retweet" style=""></i></a>
            {{/if}}
            {{#unless (unifiedOr (unifiedEq groupId "cantrips") isFlexible)}}
              {{#if (unifiedEq prepType "spontaneous")}}
                <a data-action="toggle-signature-spell" data-tooltip="PF2E.ToggleSignatureSpellTitle">
                  <i class="fa-fw fa-star {{#if isSignature}}fa-solid{{else}}fa-regular{{/if}}"></i>
                </a>
              {{/if}}
              {{#if (unifiedEq prepType "prepared")}}
                <a data-action="toggle-slot-expended" data-tooltip="{{#if expended}}PF2E.RestoreSpellTitle{{else}}PF2E.ExpendSpellTitle{{/if}}">
                  <i class="fa-solid fa-fw {{#if expended}}fa-plus-square{{else}}fa-minus-square{{/if}}"></i>
                </a>
              {{/if}}
            {{/unless}}
            {{#unless isVirtual}}
              <a data-action="edit-item" data-tooltip="PF2E.EditItemTitle">
                <i class="fa-solid fa-fw fa-edit"></i>
              </a>
              <a data-action="delete-item" data-tooltip="PF2E.DeleteItemTitle">
                <i class="fa-solid fa-fw fa-trash"></i>
              </a>
            {{/unless}}
          </div>

          <div class="item-summary" hidden=""></div>
        </li>
        {{/each}}
        {{!-- end spells --}}

      {{/each}}
      {{!-- end sources --}}

    </ol>
  </li>
  {{/each}}
  {{!-- end ranks --}}

</ol>